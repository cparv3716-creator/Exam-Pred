# ExamIQ — environment variables
# Copy to .env.local for local dev, and set the same keys in the Vercel
# project settings (Project → Settings → Environment Variables).
# Never commit real secrets. The app builds and runs fine with these unset
# (practice works anonymously; progress simply isn't persisted).

# Public Supabase project URL (browser + server)
NEXT_PUBLIC_SUPABASE_URL=

# Public anon key — safe to expose to the browser; RLS protects the data
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service-role key — SERVER ONLY. Never prefix with NEXT_PUBLIC_.
# Only needed later for trusted server tasks (admin/cron/aggregation).
SUPABASE_SERVICE_ROLE_KEY=
